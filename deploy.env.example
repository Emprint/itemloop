# Copy this file to deploy.env and fill in your values.
# deploy.env is gitignored — never commit it.

SSH_USER=your_ssh_username
SSH_HOST=your_ssh_host
SSH_PORT=22
SSH_PASS=your_ssh_password  # used by sshpass — leave blank to be prompted

# Public URL of your deployed site (used in deploy output)
SITE_URL=https://yourdomain.com
