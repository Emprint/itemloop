APP_ENV=production
APP_DEBUG=false

DB_HOST=localhost
DB_NAME=itemloop
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Must match your domain — used for CORS and cookie settings
APP_URL=https://yourdomain.com

# Absolute path to the web-accessible image storage directory.
# Must be under the web root so images are served directly by Apache/Nginx.
# IMPORTANT on OVH shared hosting: use the real filesystem path (run `echo $HOME` via SSH),
# NOT the /home/username alias — PHP-FPM's open_basedir is set to the real path.
# Example (OVH): /homez.NNN/youraccount/yoursite/frontend/storage/products
# Example (local dev): leave unset — defaults to public/storage/products
STORAGE_PATH=/path/to/your/frontend/storage/products
